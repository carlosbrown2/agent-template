// markdownlint-cli2 config. Consumed by the markdown-lint job in
// .github/workflows/ci.yml and by any local editor integration.
//
// The gate's truth is shellcheck + bats + the register-integrity parsers,
// not prose style. Every disabled rule below conflicts with intentional
// content we want to preserve — disabling them is cheaper than rewriting
// the registers and prompt files around a linter's defaults.
{
  "default": true,
  "MD013": false,  // line-length: registers use long single-line rows by design
  "MD022": false,  // blanks-around-headings: Discovered Patterns binds `model:` directly under `### `
  "MD031": false,  // blanks-around-fences: prompt files pack fences tightly into structured sections
  "MD032": false,  // blanks-around-lists: same — lists follow headings without stylistic padding
  "MD033": false,  // inline-html: <!-- --> comments in registers
  "MD038": false,  // no-space-in-code: `### ` is the markdown heading prefix being documented
  "MD040": false,  // fenced-code-language: some blocks are generic shell output, language tag adds no signal
  "MD041": false,  // first-line-h1: some docs lead with a paragraph
  "MD056": false   // table-column-count: fails on code-span pipes (`bd list | grep`) — our parsers.sh handles this correctly
}
